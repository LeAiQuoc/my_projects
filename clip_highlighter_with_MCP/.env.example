# Required for highlight selection
DEEPSEEK_API_KEY=

# Optional: choose model for highlight extraction
HIGHLIGHT_MODEL=deepseek-chat

# Optional: override OpenAI-compatible base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Processing defaults
DEFAULT_LANGUAGE=en
DEFAULT_TOP_CLIPS=5
DEFAULT_CLIP_MIN_SECONDS=30
DEFAULT_CLIP_MAX_SECONDS=60

# Transcription runtime defaults
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8

# Reframe defaults (9:16)
VERTICAL_OUTPUT_WIDTH=1080
VERTICAL_OUTPUT_HEIGHT=1920

# Caption styling defaults for vertical output
CAPTION_FONT_SIZE=18
CAPTION_MARGIN_V=72
CAPTION_MAX_LINE_CHARS=22
